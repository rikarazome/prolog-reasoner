# prolog-reasoner configuration (library mode only).
# Copy to .env and fill in values for local development.
# The MCP server does not read any of these — it has no LLM dependency.

# LLM provider: "openai" or "anthropic"
PROLOG_REASONER_LLM_PROVIDER=openai

# API key for the chosen provider
PROLOG_REASONER_LLM_API_KEY=

# Model name
#   OpenAI:    gpt-5.4 / gpt-5.4-mini (default) / gpt-5.4-nano
#   Anthropic: claude-opus-4-6 / claude-sonnet-4-6 / claude-haiku-4-5
PROLOG_REASONER_LLM_MODEL=gpt-5.4-mini

# Optional overrides
# PROLOG_REASONER_LLM_TEMPERATURE=0.0
# PROLOG_REASONER_LLM_TIMEOUT_SECONDS=30.0
# PROLOG_REASONER_SWIPL_PATH=swipl
# PROLOG_REASONER_EXECUTION_TIMEOUT_SECONDS=10.0
# PROLOG_REASONER_LOG_LEVEL=INFO